# Watchmode API
WATCHMODE_API_KEY=your_watchmode_api_key_here

# Database (Neon.tech PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dizitaq?sslmode=require

# Upstash Redis (REST API)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# NextAuth
NEXTAUTH_SECRET=generate_with_openssl_rand_-base64_32
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret

# Admin Panel
ADMIN_SECRET=generate_a_strong_random_secret_min_32_chars

# Embed Domain Whitelist (comma-separated, no spaces)
EMBED_DOMAINS=vidcloud.example.com,vidmoly.example.net
