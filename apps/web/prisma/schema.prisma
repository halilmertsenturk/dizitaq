generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  hashedPassword String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  watchlist       Watchlist[]
  searchHistory   SearchHistory[]
  recentlyViewed  RecentlyViewed[]
  reviews         Review[]
  comments        Comment[]
  watchHistory    WatchHistory[]
  favorites       Favorite[]
  reports         Report[]
  adminLogs       AdminLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CachedTitle {
  id          String   @id @default(cuid())
  watchmodeId Int      @unique
  title       String
  type        String   // "movie" | "series"
  year        Int?
  genres      String[] // PostgreSQL array
  poster      String?
  rating      Float?
  plot        String?
  imdbId      String?
  tmdbId      Int?
  rawJson     Json?    // Full API response as fallback
  cachedAt    DateTime @default(now())

  sources        CachedSource[]
  seasons        CachedSeason[]
  watchlist      Watchlist[]
  recentlyViewed RecentlyViewed[]
  searchHistory  SearchHistory[]
  videoSources   VideoSource[]
  reviews        Review[]
  comments       Comment[]
  watchHistory   WatchHistory[]
  favorites      Favorite[]
}

model CachedSource {
  id         String @id @default(cuid())
  sourceId   Int
  name       String
  type       String
  region     String
  iosUrl     String?
  androidUrl String?
  webUrl     String?
  format     String
  price      Float?
  quality    String

  titleId String
  title   CachedTitle @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([titleId, sourceId])
}

model CachedSeason {
  id           String @id @default(cuid())
  seasonNumber Int

  titleId String
  title   CachedTitle   @relation(fields: [titleId], references: [id], onDelete: Cascade)
  episodes CachedEpisode[]

  @@unique([titleId, seasonNumber])
}

model CachedEpisode {
  id        String  @id @default(cuid())
  epNum     Int
  title     String
  synopsis  String?
  airDate   String?
  image     String?

  seasonId String
  season   CachedSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  videoSources   VideoSource[]
  watchHistory   WatchHistory[]

  @@unique([seasonId, epNum])
}

model Watchlist {
  id      String   @id @default(cuid())
  userId  String
  titleId String
  addedAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title CachedTitle @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([userId, titleId])
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  titleId   String?
  query     String
  filters   Json?    // JSON of applied filters
  createdAt DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title CachedTitle? @relation(fields: [titleId], references: [id], onDelete: Cascade)
}

model RecentlyViewed {
  id       String   @id @default(cuid())
  userId   String
  titleId  String
  viewedAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title CachedTitle @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([userId, titleId])
}

model VideoSource {
  id         String   @id @default(cuid())
  watchmodeId Int?    // for movies (null if linked to episode)
  episodeId  String?  // for TV episodes (null if linked to movie)
  embedUrl   String
  sourceName String
  quality    String?
  language   String   @default("en")
  isActive   Boolean  @default(true)
  reportsCount Int    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  title   CachedTitle?  @relation(fields: [watchmodeId], references: [watchmodeId], onDelete: Cascade)
  episode CachedEpisode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  reports   Report[]

  @@unique([watchmodeId, episodeId, sourceName])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  titleId   String
  rating    Int      // 1-10
  content   String?  // optional text review
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title CachedTitle @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([userId, titleId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  titleId   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title CachedTitle @relation(fields: [titleId], references: [id], onDelete: Cascade)
}

model WatchHistory {
  id        String   @id @default(cuid())
  userId    String
  titleId   String
  episodeId String?  // null for movies
  timestamp Int      @default(0) // seconds watched, for resume
  completed Boolean  @default(false)
  watchedAt DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title   CachedTitle    @relation(fields: [titleId], references: [id], onDelete: Cascade)
  episode CachedEpisode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, titleId, episodeId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  titleId   String
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title CachedTitle @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([userId, titleId])
}

model Report {
  id        String   @id @default(cuid())
  userId    String
  sourceId  String
  reason    String   // "broken" | "wrong" | "malicious" | "other"
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  source VideoSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String?  // null if using ADMIN_SECRET
  action     String   // "source.create" | "source.delete" | "domain.add" | etc.
  targetType String   // "source" | "domain" | "report"
  targetId   String?
  metadata   Json?    // extra data about the action
  createdAt  DateTime @default(now())

  admin User? @relation(fields: [adminId], references: [id], onDelete: SetNull)
}
